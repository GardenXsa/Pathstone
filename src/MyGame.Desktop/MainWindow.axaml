<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MyGame.Desktop.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="MyGame.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding CurrentView.Title, FallbackValue='MyGame'}"
        MinWidth="1024" MinHeight="700"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">

    <!--
        ANIMATIONS (issue #46 #4a): wrap the shell content in a
        TransitioningContentControl so that switching screens
        (MainViewModel.CurrentView changes) cross-fades the old view
        out and the new view in over ~250 ms. The PageTransition is a
        CrossFade with CubicEaseOut easing — short + subtle, never
        flashy. When Settings.EnableAnimations is false, ThemeService
        removes the Window's "Anim" class and the
        Window.Anim TransitioningContentControl style overrides
        PageTransition to null (instant swap).
    -->
    <TransitioningContentControl Content="{Binding CurrentView}">
        <TransitioningContentControl.PageTransition>
            <CrossFade Duration="0:0:0.25" />
        </TransitioningContentControl.PageTransition>
    </TransitioningContentControl>
</Window>
