<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels"
             xmlns:conv="using:MyGame.Desktop.Converters"
             xmlns:panels="using:MyGame.Desktop.Views.Panels"
             xmlns:core="using:MyGame.Core.Saves"
             xmlns:mp="using:MyGame.Core.Multiplayer"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="MyGame.Desktop.Views.GameView"
             x:DataType="vm:GameViewModel"
             KeyDown="OnGlobalKeyDown">

    <Grid>
        <DockPanel LastChildFill="True">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Classes="TopBar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding GameName}" Classes="AppTitle"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ShareAddress}" Classes="Muted Small"
                           VerticalAlignment="Center" IsVisible="{Binding IsMultiplayer}"/>
                <!-- COMBAT-DEATH (issue #88): combat indicator. Red text,
                     only visible when CombatDisplay is non-empty. -->
                <TextBlock Grid.Column="2" Text="{Binding CombatDisplay}"
                           Foreground="{DynamicResource AppDangerBrush}"
                           FontWeight="SemiBold" Classes="Small"
                           VerticalAlignment="Center" Margin="12,0"
                           IsVisible="{Binding CombatDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Grid.Column="3" Text="{Binding ClockDisplay}" Classes="Muted Small"
                           VerticalAlignment="Center" Margin="12,0"
                           FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                <!-- Token billing widget (issue #6) — monospace, two
                     TextBlocks in a horizontal StackPanel so each can
                     collapse independently when its value is empty. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0" Spacing="8"
                            ToolTip.Tip="Использование токенов AI за этот ход и сессию">
                    <TextBlock Text="{Binding LastTurnTokensDisplay}" Classes="Muted Small"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                               IsVisible="{Binding LastTurnTokensDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SessionTokensDisplay}" Classes="Muted Small"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                               IsVisible="{Binding SessionTokensDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <Button Grid.Column="5" Content="💾 Сохранить" Command="{Binding SaveCommand}"
                        Classes="SmallButton" Margin="0,0,6,0"
                        IsVisible="{Binding CanSave}"
                        ToolTip.Tip="Сохранить текущее состояние"/>
                <Button Grid.Column="6" Content="Выйти" Command="{Binding LeaveGameCommand}"
                        Classes="SmallButton Danger"
                        ToolTip.Tip="Выйти из игры"/>
            </Grid>
        </Border>

        <!-- Status bar (below top bar) -->
        <Border DockPanel.Dock="Top" Classes="StatusBar">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Classes="Muted Small"/>
                <TextBlock Grid.Column="1" Text="⏳" IsVisible="{Binding IsWaiting}"
                           Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <!-- Error bar -->
        <Border DockPanel.Dock="Top" Classes="ErrorBar"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" />
        </Border>

        <!-- 3-column body. Right column collapses to 0 width in single-player. -->
        <Grid ColumnDefinitions="320,*,Auto">

            <!-- LEFT column: members (multiplayer) OR tabbed panels (single-player) -->
            <Border Grid.Column="0" Classes="SidePanel">
                <DockPanel LastChildFill="True">
                    <!-- Multiplayer: members list. Issue #77 — shows a
                         ready-status indicator (✓ ready / ○ pending) next
                         to each member. In-game, the indicator reflects
                         the post-start Playing status (everyone shows ✓). -->
                    <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsMultiplayer}">
                        <TextBlock Text="Участники" Classes="SectionTitle" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding Members}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="mp:MemberInfo">
                                    <Border Classes="MemberRow" Padding="6,4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="1">
                                                <TextBlock Text="{Binding Nickname}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Role}" Classes="Muted Small"/>
                                            </StackPanel>
                                            <!-- Ready-status indicator. ✓ for Ready, ○ for Pending. -->
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AppSuccessBrush}"
                                                       Text="✓"
                                                       ToolTip.Tip="Готов"
                                                       IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Ready}"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AppMutedBrush}"
                                                       Text="○"
                                                       ToolTip.Tip="Ожидание"
                                                       IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Pending}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Single-player: tabbed side panels (Character / Inventory / Quests / World) -->
                    <TabControl x:Name="SideTabs" IsVisible="{Binding !IsMultiplayer}" Padding="0">
                        <TabItem Header="Персонаж" ToolTip.Tip="Лист персонажа">
                            <panels:CharacterPanelView DataContext="{Binding CharacterPanel}"/>
                        </TabItem>
                        <TabItem Header="Сумка" ToolTip.Tip="Инвентарь и экипировка">
                            <panels:InventoryPanelView DataContext="{Binding InventoryPanel}"/>
                        </TabItem>
                        <TabItem Header="Квесты" ToolTip.Tip="Журнал заданий">
                            <panels:QuestPanelView DataContext="{Binding QuestPanel}"/>
                        </TabItem>
                        <TabItem Header="Мир" ToolTip.Tip="Карта мира и текущая локация">
                            <panels:WorldPanelView DataContext="{Binding WorldPanel}"/>
                        </TabItem>
                    </TabControl>

                    <!-- Bottom: chat panel (multiplayer only). Issue #77
                         — stays visible in lobby mode (pre-game chat). -->
                    <Border DockPanel.Dock="Bottom" Classes="ChatPanel"
                            IsVisible="{Binding IsMultiplayer}" Margin="0,8,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Чат" Classes="SectionTitle" Margin="0,0,0,4"/>
                            <Button DockPanel.Dock="Bottom" Content="Отправить" AutomationProperties.Name="Отправить сообщение в чат"
                                    Command="{Binding SendChatCommand}" Classes="SmallButton"
                                    Margin="0,4,0,0"
                                    ToolTip.Tip="Отправить сообщение в чат"/>
                            <TextBox DockPanel.Dock="Bottom" Text="{Binding ChatInput}"
                                     PlaceholderText="Сообщение…"
                                     Margin="0,4,0,0"
                                     ToolTip.Tip="Сообщение участникам партии"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ChatLine">
                                            <StackPanel Margin="0,2">
                                                <TextBlock>
                                                    <Run Text="{Binding Author}" FontWeight="SemiBold"/>
                                                    <Run Text=": " />
                                                    <Run Text="{Binding Text}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Spacer to fill remaining height -->
                    <TextBlock Text="" />
                </DockPanel>
            </Border>

            <!-- CENTER column: lobby panel (issue #77) when IsLobby, OR
                 the normal narrative log + input when !IsLobby. Both
                 children overlap in the Grid; visibility binding toggles
                 which is shown. -->
            <Border Grid.Column="1" Classes="CenterPanel">
                <Grid>

                    <!-- Lobby layout (issue #77). Visible only in
                         multiplayer + when the party status is Lobby.
                         Shows the party name, a copy-address button,
                         party settings summary, the local ready toggle
                         (clients only), and the Start Game button
                         (host only, disabled until all non-spectator
                         members are Ready). -->
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="24,16"
                                  IsVisible="{Binding IsLobby}">
                        <StackPanel Spacing="14" MaxWidth="560" HorizontalAlignment="Center">
                            <TextBlock Text="Лобби партии" Classes="ScreenTitle"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding GameName}" FontSize="20"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"/>

                            <!-- Share address with copy button (host shows the
                                 listen address; clients show the host they
                                 connected to). -->
                            <Border Classes="InfoBox" Padding="10"
                                    IsVisible="{Binding ShareAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Адрес для подключения:" Classes="Muted Small"/>
                                        <TextBlock Text="{Binding ShareAddress}"
                                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="📋 Копировать"
                                            Classes="TinyButton" VerticalAlignment="Center"
                                            Click="OnCopyAddressClick"
                                            ToolTip.Tip="Скопировать адрес в буфер обмена"/>
                                </Grid>
                            </Border>

                            <!-- Party settings summary. Static labels
                                 describing the host's configuration. The
                                 MaxPlayers cap + turn model are set at
                                 host-creation time on the HostGame screen;
                                 we surface them here as a quick reminder.
                                 Future: bind to live host settings when
                                 they're exposed on the HostSession. -->
                            <Border Classes="PanelSection" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Настройки партии" Classes="SectionTitle"/>
                                    <TextBlock Text="Модель хода: батчинг действий (5 секунд)"
                                               Classes="Muted Small"/>
                                    <TextBlock Text="Видимость: локальная сеть (LAN)"
                                               Classes="Muted Small"/>
                                    <TextBlock Text="Хост управляет переходом в игру — дождитесь готовности всех участников."
                                               Classes="Muted Small" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Members list with ready-status indicators.
                                 Mirrors the left-column list but laid out
                                 larger so the host can quickly scan who's
                                 ready. -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Участники лобби" Classes="SectionTitle"/>
                                <ItemsControl ItemsSource="{Binding Members}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="mp:MemberInfo">
                                            <Border Classes="MemberRow" Padding="8,5">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="1">
                                                        <TextBlock Text="{Binding Nickname}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Role}" Classes="Muted Small"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                               Margin="8,0"
                                                               Classes="Muted Small"
                                                               Text="готов"
                                                               Foreground="{DynamicResource AppSuccessBrush}"
                                                               IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Ready}"/>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                               Margin="8,0"
                                                               Classes="Muted Small"
                                                               Text="ожидание"
                                                               IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Pending}"/>
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                               FontSize="18"
                                                               Foreground="{DynamicResource AppSuccessBrush}"
                                                               Text="✓"
                                                               IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Ready}"/>
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                                               FontSize="18"
                                                               Foreground="{DynamicResource AppMutedBrush}"
                                                               Text="○"
                                                               IsVisible="{Binding Status, Converter={x:Static conv:MemberStatusToReadyVisibilityConverter.Instance}, ConverterParameter=Pending}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Lobby action buttons. Clients see the
                                 Ready toggle; hosts see the Start Game
                                 button. -->
                            <StackPanel Spacing="8" Margin="0,8,0,0">
                                <!-- Client: ready toggle -->
                                <Button Content="✓ Готов"
                                        Command="{Binding ToggleReadyCommand}"
                                        Classes="MenuButton Primary"
                                        HorizontalAlignment="Stretch"
                                        IsVisible="{Binding IsClient}"
                                        ToolTip.Tip="Отметиться готовым (или отменить готовность)"/>
                                <TextBlock Text="Хост всегда готов и запускает игру."
                                           Classes="Muted Small"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding IsClient}"/>

                                <!-- Host: start game -->
                                <Button Content="▶ Начать игру"
                                        Command="{Binding StartGameCommand}"
                                        Classes="MenuButton Primary"
                                        HorizontalAlignment="Stretch"
                                        IsVisible="{Binding IsHost}"
                                        ToolTip.Tip="Перевести партию в режим игры (все участники должны быть готовы)"/>
                                <TextBlock Text="Доступно, когда все участники готовы."
                                           Classes="Muted Small"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding IsHost}"/>
                            </StackPanel>

                            <TextBlock Text="Чат доступен слева — общайтесь до старта."
                                       Classes="Muted Small"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Normal game layout: narrative log + action input.
                         Hidden in lobby mode. -->
                    <DockPanel LastChildFill="True"
                               IsVisible="{Binding !IsLobby}">
                        <!-- Input box at bottom -->
                        <Border DockPanel.Dock="Bottom" Classes="InputBar" Padding="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" x:Name="ActionInput" Text="{Binding CurrentAction}" AutomationProperties.Name="Поле ввода действия игрока"
                                         PlaceholderText="Опишите действие вашего персонажа…"
                                         IsEnabled="{Binding CanSubmit}"
                                         KeyDown="OnActionKeyDown"
                                         ToolTip.Tip="Опишите действие вашего персонажа"/>
                                <Button Grid.Column="1" Content="Отправить" AutomationProperties.Name="Отправить действие игровому мастеру"
                                        Command="{Binding SubmitActionCommand}"
                                        Classes="SmallButton Primary"
                                        Margin="6,0,0,0"
                                        IsEnabled="{Binding CanSubmit}"
                                        ToolTip.Tip="Отправить действие GM"/>
                            </Grid>
                        </Border>

                        <!-- Narrative stream -->
                        <ScrollViewer x:Name="NarrativeScroll"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Log}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="core:LogEntry">
                                            <Border Classes="LogEntry" Padding="6,4">
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Live-streaming narrative text (issue #5).
                                     Bound to StreamingNarrativeText on the VM,
                                     which is throttled to ~50ms-per-update to
                                     avoid flooding the UI. Visible only while
                                     the GM is actively streaming a turn; cleared
                                     the moment the final NarrativeResult is
                                     appended to the Log above. -->
                                <Border Classes="LogEntry StreamingEntry" Padding="6,4"
                                        IsVisible="{Binding StreamingNarrativeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding StreamingNarrativeText}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- RIGHT column: multiplayer-only pending-actions queue.
                 Hidden in single-player AND in lobby mode (no actions
                 queued yet — the game hasn't started). -->
            <Border Grid.Column="2" Classes="SidePanel" Width="260"
                    IsVisible="{Binding IsMultiplayer}">
                <DockPanel LastChildFill="True">
                    <!-- Multiplayer: pending actions -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Очередь действий" Classes="SectionTitle" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding PendingActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="mp:PlayerAction">
                                    <Border Classes="ActionRow" Padding="6,4">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding PlayerNickname}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       Classes="Small Muted"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(пусто)" Classes="Muted Small" Margin="0,4,0,0"
                                   IsVisible="{Binding !PendingActions.Count}"/>
                    </StackPanel>

                    <TextBlock Text="" />
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>

        <!-- COMBAT-DEATH (issue #63): death overlay. Covers the game
             screen with a semi-opaque panel showing the death message
             + two options: reload the last save (loses progress since
             last save) or leave to the main menu (without saving the
             dead state). Only visible when IsPlayerDead = true. -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsPlayerDead}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppDangerBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="💀" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ваш персонаж погиб."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppDangerBrush}"/>
                    <TextBlock Text="Путь окончен. Выберите, что делать дальше."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <Button Content="↺ Загрузить последнее сохранение"
                            Command="{Binding ReloadLastSaveCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Перезагрузить текущее сохранение (прогресс после последнего сохранения будет потерян)"/>
                    <Button Content="🚪 Выйти в меню"
                            Command="{Binding LeaveToMenuCommand}"
                            Classes="MenuButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Выйти в главное меню без сохранения текущего состояния"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- RECONNECT (issue #7): disconnect overlay. Covers the game
             screen with a semi-opaque panel when the client WebSocket
             drops unexpectedly (network failure, host shutdown). Two
             variants share the overlay:

             1) Default (ReconnectFailed = false): shows the disconnect
                reason + a "Переподключиться" button (calls
                ReconnectCommand, retries 3x with 2s backoff) + a
                "Выйти в меню" button (calls LeaveToMenuCommand).
             2) Failed (ReconnectFailed = true): all 3 reconnect
                attempts failed; switches to a "Не удалось
                переподключиться" message with only the exit button.

             Suppressed entirely when IsDisconnected = false (normal
             play, intentional leave, or kick — the Kicked event
             surfaces its own inline error via OnClientKicked). -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsDisconnected}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppDangerBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="📡" FontSize="48" HorizontalAlignment="Center"/>
                    <!-- Default state: "Соединение потеряно" -->
                    <TextBlock Text="Соединение потеряно."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppDangerBrush}"
                               IsVisible="{Binding !ReconnectFailed}"/>
                    <TextBlock Text="{Binding DisconnectReason, StringFormat='Причина: {0}'}"
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"
                               IsVisible="{Binding !ReconnectFailed}"/>
                    <!-- Failed state: "Не удалось переподключиться" -->
                    <TextBlock Text="Не удалось переподключиться."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppDangerBrush}"
                               IsVisible="{Binding ReconnectFailed}"/>
                    <TextBlock Text="Сервер недоступен. Проверьте соединение и попробуйте позже."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"
                               IsVisible="{Binding ReconnectFailed}"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <!-- Reconnect button — only in default state -->
                    <Button Content="↺ Переподключиться"
                            Command="{Binding ReconnectCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding !ReconnectFailed}"
                            ToolTip.Tip="Переподключиться к хосту (3 попытки с задержкой 2 с)"/>
                    <Button Content="🚪 Выйти в меню"
                            Command="{Binding LeaveToMenuCommand}"
                            Classes="MenuButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Выйти в главное меню"/>
                    <!-- Issue #28: save the last known world state locally
                         so the player can continue solo. Only shown when
                         reconnection has failed AND the world hasn't been
                         saved yet. -->
                    <Button Content="💾 Сохранить мир локально"
                            Command="{Binding SaveWorldLocallyCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding ReconnectFailed}"
                            IsEnabled="{Binding !HasSavedWorldLocally}"
                            ToolTip.Tip="Сохранить последнее известное состояние мира как одиночное сохранение"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- REGION GENERATION OVERLAY (issue #20 — chunked generation).
             Shown while the orchestrator generates a cold region on
             demand (after the player clicks a phantom exit). Non-modal:
             the user can't act while it's up, but it disappears
             automatically on completion. ZIndex 90 keeps it below the
             death/reconnect modal overlays (ZIndex 100). -->
        <Border Background="#B0000000"
                IsVisible="{Binding IsRegionGenerating}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="90">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppAccentBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="🌍" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Генерация региона…"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppAccentBrush}"/>
                    <TextBlock Text="{Binding RegionGenerationStatus}"
                               Classes="Muted"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Height="6" Width="240"/>
                    <TextBlock Text="AI достраивает регион — это займёт 20-60 секунд. Не закрывайте приложение."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- KEYBOARD-SHORTCUTS (issue #51): F1 help overlay. Lists all
             shortcuts. Toggled via OnGlobalKeyDown (F1 or Esc).
             Click anywhere on the dim backdrop to dismiss. ZIndex 50
             keeps it above the main DockPanel but below the
             death/reconnect modal overlays (ZIndex 100) so those
             stay interactive when both happen to be visible. -->
        <Border x:Name="HelpOverlay"
                Background="#CC000000"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="50"
                PointerPressed="OnHelpOverlayClick">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="32,24" MinWidth="460" MaxWidth="620">
                <StackPanel Spacing="12">
                    <TextBlock Text="⌨ Горячие клавиши" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <StackPanel Spacing="5">
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Enter" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Отправить действие"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Ctrl+Enter" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Отправить + вернуть фокус на ввод (быстрый темп)"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Esc" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Очистить ввод"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Ctrl+S" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Сохранить игру"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Ctrl+L" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Выйти из игры (с подтверждением)"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="1, 2, 3, 4" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Переключить панели (Персонаж / Сумка / Квесты / Мир)"/>
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="F1" FontWeight="SemiBold"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                            <TextBlock Grid.Column="1" Text="Эта подсказка"/>
                        </Grid>
                    </StackPanel>
                    <Border Classes="Separator" Margin="0,4"/>
                    <TextBlock Text="Нажмите F1 или Esc, чтобы закрыть. Цифры 1–4 не работают, когда фокус в поле ввода."
                               Classes="Muted Small" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- KEYBOARD-SHORTCUTS (issue #51): Ctrl+L confirm overlay.
             Asks the user to confirm leaving the game. "Выйти" calls
             LeaveGameCommand directly; "Отмена" hides the overlay.
             Esc also cancels, Enter confirms (handled in
             OnGlobalKeyDown). ZIndex 51 — one above the help overlay
             so the user can dismiss the help overlay first if both
             happen to be visible. -->
        <Border x:Name="LeaveConfirmOverlay"
                Background="#CC000000"
                IsVisible="False"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="51"
                PointerPressed="OnLeaveConfirmOverlayClick">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppDangerBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="🚪" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Выйти из игры?"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppDangerBrush}"/>
                    <TextBlock Text="Несохранённый прогресс может быть потерян. Перед выходом рекомендуется сохранить (Ctrl+S)."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <Button Content="Выйти" Command="{Binding LeaveGameCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            Click="OnLeaveConfirmAccept"
                            ToolTip.Tip="Выйти из игры"/>
                    <Button Content="Отмена" Classes="MenuButton"
                            HorizontalAlignment="Stretch"
                            Click="OnLeaveConfirmCancel"
                            ToolTip.Tip="Остаться в игре"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
