<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels"
             xmlns:panels="using:MyGame.Desktop.Views.Panels"
             xmlns:core="using:MyGame.Core.Saves"
             xmlns:mp="using:MyGame.Core.Multiplayer"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="MyGame.Desktop.Views.GameView"
             x:DataType="vm:GameViewModel">

    <Grid>
        <DockPanel LastChildFill="True">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Classes="TopBar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding GameName}" Classes="AppTitle"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ShareAddress}" Classes="Muted Small"
                           VerticalAlignment="Center" IsVisible="{Binding IsMultiplayer}"/>
                <!-- COMBAT-DEATH (issue #88): combat indicator. Red text,
                     only visible when CombatDisplay is non-empty. -->
                <TextBlock Grid.Column="2" Text="{Binding CombatDisplay}"
                           Foreground="{StaticResource AppDangerBrush}"
                           FontWeight="SemiBold" Classes="Small"
                           VerticalAlignment="Center" Margin="12,0"
                           IsVisible="{Binding CombatDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Grid.Column="3" Text="{Binding ClockDisplay}" Classes="Muted Small"
                           VerticalAlignment="Center" Margin="12,0"
                           FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                <!-- Token billing widget (issue #6) — monospace, two
                     TextBlocks in a horizontal StackPanel so each can
                     collapse independently when its value is empty. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0" Spacing="8"
                            ToolTip.Tip="Использование токенов AI за этот ход и сессию">
                    <TextBlock Text="{Binding LastTurnTokensDisplay}" Classes="Muted Small"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                               IsVisible="{Binding LastTurnTokensDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding SessionTokensDisplay}" Classes="Muted Small"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                               IsVisible="{Binding SessionTokensDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <Button Grid.Column="5" Content="💾 Сохранить" Command="{Binding SaveCommand}"
                        Classes="SmallButton" Margin="0,0,6,0"
                        IsVisible="{Binding CanSave}"
                        ToolTip.Tip="Сохранить текущее состояние"/>
                <Button Grid.Column="6" Content="Выйти" Command="{Binding LeaveGameCommand}"
                        Classes="SmallButton Danger"
                        ToolTip.Tip="Выйти из игры"/>
            </Grid>
        </Border>

        <!-- Status bar (below top bar) -->
        <Border DockPanel.Dock="Top" Classes="StatusBar">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Classes="Muted Small"/>
                <TextBlock Grid.Column="1" Text="⏳" IsVisible="{Binding IsWaiting}"
                           Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <!-- Error bar -->
        <Border DockPanel.Dock="Top" Classes="ErrorBar"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" />
        </Border>

        <!-- 3-column body. Right column collapses to 0 width in single-player. -->
        <Grid ColumnDefinitions="320,*,Auto">

            <!-- LEFT column: members (multiplayer) OR tabbed panels (single-player) -->
            <Border Grid.Column="0" Classes="SidePanel">
                <DockPanel LastChildFill="True">
                    <!-- Multiplayer: members list -->
                    <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsMultiplayer}">
                        <TextBlock Text="Участники" Classes="SectionTitle" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding Members}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="mp:MemberInfo">
                                    <Border Classes="MemberRow" Padding="6,4">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding Nickname}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Role}" Classes="Muted Small"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Single-player: tabbed side panels (Character / Inventory / Quests / World) -->
                    <TabControl IsVisible="{Binding !IsMultiplayer}" Padding="0">
                        <TabItem Header="Персонаж" ToolTip.Tip="Лист персонажа">
                            <panels:CharacterPanelView DataContext="{Binding CharacterPanel}"/>
                        </TabItem>
                        <TabItem Header="Сумка" ToolTip.Tip="Инвентарь и экипировка">
                            <panels:InventoryPanelView DataContext="{Binding InventoryPanel}"/>
                        </TabItem>
                        <TabItem Header="Квесты" ToolTip.Tip="Журнал заданий">
                            <panels:QuestPanelView DataContext="{Binding QuestPanel}"/>
                        </TabItem>
                        <TabItem Header="Мир" ToolTip.Tip="Карта мира и текущая локация">
                            <panels:WorldPanelView DataContext="{Binding WorldPanel}"/>
                        </TabItem>
                    </TabControl>

                    <!-- Bottom: chat panel (multiplayer only) -->
                    <Border DockPanel.Dock="Bottom" Classes="ChatPanel"
                            IsVisible="{Binding IsMultiplayer}" Margin="0,8,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Чат" Classes="SectionTitle" Margin="0,0,0,4"/>
                            <Button DockPanel.Dock="Bottom" Content="Отправить"
                                    Command="{Binding SendChatCommand}" Classes="SmallButton"
                                    Margin="0,4,0,0"
                                    ToolTip.Tip="Отправить сообщение в чат"/>
                            <TextBox DockPanel.Dock="Bottom" Text="{Binding ChatInput}"
                                     PlaceholderText="Сообщение…"
                                     Margin="0,4,0,0"
                                     ToolTip.Tip="Сообщение участникам партии"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ChatLine">
                                            <StackPanel Margin="0,2">
                                                <TextBlock>
                                                    <Run Text="{Binding Author}" FontWeight="SemiBold"/>
                                                    <Run Text=": " />
                                                    <Run Text="{Binding Text}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Spacer to fill remaining height -->
                    <TextBlock Text="" />
                </DockPanel>
            </Border>

            <!-- CENTER column: narrative log + input -->
            <Border Grid.Column="1" Classes="CenterPanel">
                <DockPanel LastChildFill="True">
                    <!-- Input box at bottom -->
                    <Border DockPanel.Dock="Bottom" Classes="InputBar" Padding="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding CurrentAction}"
                                     PlaceholderText="Опишите действие вашего персонажа…"
                                     IsEnabled="{Binding CanSubmit}"
                                     KeyDown="OnActionKeyDown"
                                     ToolTip.Tip="Опишите действие вашего персонажа"/>
                            <Button Grid.Column="1" Content="Отправить"
                                    Command="{Binding SubmitActionCommand}"
                                    Classes="SmallButton Primary"
                                    Margin="6,0,0,0"
                                    IsEnabled="{Binding CanSubmit}"
                                    ToolTip.Tip="Отправить действие GM"/>
                        </Grid>
                    </Border>

                    <!-- Narrative stream -->
                    <ScrollViewer x:Name="NarrativeScroll"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Log}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="core:LogEntry">
                                        <Border Classes="LogEntry" Padding="6,4">
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Live-streaming narrative text (issue #5).
                                 Bound to StreamingNarrativeText on the VM,
                                 which is throttled to ~50ms-per-update to
                                 avoid flooding the UI. Visible only while
                                 the GM is actively streaming a turn; cleared
                                 the moment the final NarrativeResult is
                                 appended to the Log above. -->
                            <Border Classes="LogEntry StreamingEntry" Padding="6,4"
                                    IsVisible="{Binding StreamingNarrativeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding StreamingNarrativeText}" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- RIGHT column: multiplayer-only pending-actions queue. Hidden in single-player. -->
            <Border Grid.Column="2" Classes="SidePanel" Width="260"
                    IsVisible="{Binding IsMultiplayer}">
                <DockPanel LastChildFill="True">
                    <!-- Multiplayer: pending actions -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Очередь действий" Classes="SectionTitle" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding PendingActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="mp:PlayerAction">
                                    <Border Classes="ActionRow" Padding="6,4">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding PlayerNickname}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       Classes="Small Muted"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(пусто)" Classes="Muted Small" Margin="0,4,0,0"
                                   IsVisible="{Binding !PendingActions.Count}"/>
                    </StackPanel>

                    <TextBlock Text="" />
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>

        <!-- COMBAT-DEATH (issue #63): death overlay. Covers the game
             screen with a semi-opaque panel showing the death message
             + two options: reload the last save (loses progress since
             last save) or leave to the main menu (without saving the
             dead state). Only visible when IsPlayerDead = true. -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsPlayerDead}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppDangerBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="💀" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ваш персонаж погиб."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AppDangerBrush}"/>
                    <TextBlock Text="Путь окончен. Выберите, что делать дальше."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <Button Content="↺ Загрузить последнее сохранение"
                            Command="{Binding ReloadLastSaveCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Перезагрузить текущее сохранение (прогресс после последнего сохранения будет потерян)"/>
                    <Button Content="🚪 Выйти в меню"
                            Command="{Binding LeaveToMenuCommand}"
                            Classes="MenuButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Выйти в главное меню без сохранения текущего состояния"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- RECONNECT (issue #7): disconnect overlay. Covers the game
             screen with a semi-opaque panel when the client WebSocket
             drops unexpectedly (network failure, host shutdown). Two
             variants share the overlay:

             1) Default (ReconnectFailed = false): shows the disconnect
                reason + a "Переподключиться" button (calls
                ReconnectCommand, retries 3x with 2s backoff) + a
                "Выйти в меню" button (calls LeaveToMenuCommand).
             2) Failed (ReconnectFailed = true): all 3 reconnect
                attempts failed; switches to a "Не удалось
                переподключиться" message with only the exit button.

             Suppressed entirely when IsDisconnected = false (normal
             play, intentional leave, or kick — the Kicked event
             surfaces its own inline error via OnClientKicked). -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsDisconnected}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppDangerBrush}"
                    BorderThickness="2" CornerRadius="8"
                    Padding="40,30" MinWidth="380" MaxWidth="560">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <TextBlock Text="📡" FontSize="48" HorizontalAlignment="Center"/>
                    <!-- Default state: "Соединение потеряно" -->
                    <TextBlock Text="Соединение потеряно."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AppDangerBrush}"
                               IsVisible="{Binding !ReconnectFailed}"/>
                    <TextBlock Text="{Binding DisconnectReason, StringFormat='Причина: {0}'}"
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"
                               IsVisible="{Binding !ReconnectFailed}"/>
                    <!-- Failed state: "Не удалось переподключиться" -->
                    <TextBlock Text="Не удалось переподключиться."
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AppDangerBrush}"
                               IsVisible="{Binding ReconnectFailed}"/>
                    <TextBlock Text="Сервер недоступен. Проверьте соединение и попробуйте позже."
                               Classes="Muted Small"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center"
                               IsVisible="{Binding ReconnectFailed}"/>
                    <Border Classes="Separator" Margin="0,4"/>
                    <!-- Reconnect button — only in default state -->
                    <Button Content="↺ Переподключиться"
                            Command="{Binding ReconnectCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding !ReconnectFailed}"
                            ToolTip.Tip="Переподключиться к хосту (3 попытки с задержкой 2 с)"/>
                    <Button Content="🚪 Выйти в меню"
                            Command="{Binding LeaveToMenuCommand}"
                            Classes="MenuButton"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Выйти в главное меню"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
