<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MyGame.Desktop.ViewModels"
             xmlns:panels="clr-namespace:MyGame.Desktop.Views.Panels"
             xmlns:controls="clr-namespace:MyGame.Desktop.Controls"
             x:Class="MyGame.Desktop.Views.GameView"
             x:DataType="vm:GameViewModel"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton:pointerover">
            <Setter Property="Background" Value="#33D97706" />
            <Setter Property="RenderTransform" Value="scale(1.1)" />
        </Style>
        <Style Selector="ToggleButton:checked">
            <Setter Property="Background" Value="#66D97706" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccent}" />
            <Setter Property="RenderTransform" Value="scale(1.05)" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Background Texture Panel -->
        <Panel Background="{DynamicResource AppBackground}" />

        <!-- Multi-Drawer Asymmetric RPG Grid -->
        <Grid ColumnDefinitions="Auto, Auto, Auto, *, Auto, Auto, Auto" Margin="8">
            
            <!-- LEFT UTILITY BAR: Icons for Character & Inventory (Column 0) -->
            <Border Grid.Column="0" Width="52" Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,1,0" Padding="0,16" Margin="0,0,4,0">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <ToggleButton Name="CharacterToggle" Content="👤" ToolTip.Tip="Лист персонажа" IsChecked="True" />
                    <ToggleButton Name="InventoryToggle" Content="🎒" ToolTip.Tip="Инвентарь и сумка" />
                </StackPanel>
            </Border>

            <!-- LEFT DRAWER 1: Character Panel (Column 1) -->
            <Border Grid.Column="1" Width="320" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,1,0" CornerRadius="4" IsVisible="{Binding #CharacterToggle.IsChecked}" Margin="0,0,8,0" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="{DynamicResource AppSurfaceAlt}" Height="36" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Лист персонажа" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource AppForeground}" />
                    </Border>
                    <panels:CharacterPanelView Grid.Row="1" DataContext="{Binding CharacterPanel}" />
                </Grid>
            </Border>

            <!-- LEFT DRAWER 2: Inventory Panel (Column 2) -->
            <Border Grid.Column="2" Width="320" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,1,0" CornerRadius="4" IsVisible="{Binding #InventoryToggle.IsChecked}" Margin="0,0,8,0" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="{DynamicResource AppSurfaceAlt}" Height="36" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Сумка и снаряжение" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource AppForeground}" />
                    </Border>
                    <panels:InventoryPanelView Grid.Row="1" DataContext="{Binding InventoryPanel}" />
                </Grid>
            </Border>

            <!-- CENTER COLUMN: Game narrative terminal (Column 3) -->
            <Grid Grid.Column="3" RowDefinitions="*, Auto" Margin="4,0">
                <!-- Narrative viewport -->
                <Border Grid.Row="0" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Header bar -->
                        <Border Background="{DynamicResource AppSurfaceAlt}" Height="40" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1" Padding="16,0">
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <TextBlock Text="{Binding ClockDisplay}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource AppForeground}" />
                                <TextBlock Grid.Column="1" Text="{Binding SessionTokensDisplay}" Margin="12,0" VerticalAlignment="Center" Foreground="{DynamicResource AppMuted}" FontSize="11" />
                                <TextBlock Grid.Column="2" Text="{Binding CombatDisplay}" Foreground="{DynamicResource AppDanger}" FontWeight="Bold" VerticalAlignment="Center" IsVisible="{Binding IsCombatActive}" />
                            </Grid>
                        </Border>
                        
                        <!-- Narrative Scroll -->
                        <ScrollViewer Name="NarrativeScroll" Grid.Row="1" Padding="16">
                            <StackPanel Spacing="14">
                                <ItemsControl ItemsSource="{Binding Log}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="14,12" Margin="0,0,0,10" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                                                <controls:MarkdownTextBlock Markdown="{Binding Text}" TextWrapping="Wrap" LineHeight="20" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Border CornerRadius="6" Padding="14,12" Background="{DynamicResource AppSurfaceAlt}" BorderBrush="{DynamicResource AppAccent}" BorderThickness="1" IsVisible="{Binding IsStreaming}">
                                    <controls:MarkdownTextBlock Markdown="{Binding StreamingNarrativeText}" TextWrapping="Wrap" LineHeight="20" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- GLOWING MEDIEVAL GM THINKING OVERLAY -->
                        <Border Grid.Row="1" Background="#EA110E0C" IsVisible="{Binding IsWaiting}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                                <TextBlock Text="🔮" FontSize="48" HorizontalAlignment="Center" />
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Связующие нити судьбы плетутся..." HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource AppAccent}" />
                                    <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" FontSize="11" Foreground="{DynamicResource AppMuted}" />
                                </StackPanel>
                                <ProgressBar IsIndeterminate="True" Width="200" Height="3" Foreground="{DynamicResource AppAccent}" Background="Transparent" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- FIXED DOCKED TERMINAL -->
                <Border Grid.Row="1" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="8" Margin="0,12,0,0" Padding="14">
                    <Grid RowDefinitions="Auto, Auto">
                        <!-- Quick Actions -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
                            <Button Content="👁 Осмотреться" Command="{Binding QuickActionCommand}" CommandParameter="look" FontSize="11" Padding="10,5" />
                            <Button Content="🔍 Обыскать" Command="{Binding QuickActionCommand}" CommandParameter="search" FontSize="11" Padding="10,5" />
                            <Button Content="💤 Отдохнуть" Command="{Binding QuickActionCommand}" CommandParameter="rest" FontSize="11" Padding="10,5" />
                            <Button Content="🚪 Путь" Command="{Binding QuickActionCommand}" CommandParameter="travel" FontSize="11" Padding="10,5" />
                            <Button Content="🗣 Говорить" Command="{Binding QuickActionCommand}" CommandParameter="talk" FontSize="11" Padding="10,5" />
                        </StackPanel>
                        
                        <!-- Main Terminal Text Input -->
                        <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
                            <TextBox Name="ActionInput" 
                                     Text="{Binding CurrentAction, Mode=TwoWay}" 
                                     PlaceholderText="Опишите ваше следующее действие... (Shift+Enter для переноса)" 
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap" 
                                     MaxHeight="100" 
                                     MinHeight="40" 
                                     VerticalContentAlignment="Center"
                                     KeyDown="OnActionKeyDown"
                                     BorderBrush="{DynamicResource AppBorder}" />
                            <Button Grid.Column="1" 
                                    Content="Отправить" 
                                    Command="{Binding SubmitActionCommand}" 
                                    Margin="10,0,0,0" 
                                    VerticalAlignment="Stretch" 
                                    MinWidth="100" 
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT DRAWER 1: Quest Log (Column 4) -->
            <Border Grid.Column="4" Width="320" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1,0,0,0" CornerRadius="4" IsVisible="{Binding #QuestsToggle.IsChecked}" Margin="8,0,0,0" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="{DynamicResource AppSurfaceAlt}" Height="36" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Активные Квесты" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource AppForeground}" />
                    </Border>
                    <panels:QuestPanelView Grid.Row="1" DataContext="{Binding QuestPanel}" />
                </Grid>
            </Border>

            <!-- RIGHT DRAWER 2: World Map (Column 5) -->
            <Border Grid.Column="5" Width="320" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1,0,0,0" CornerRadius="4" IsVisible="{Binding #WorldToggle.IsChecked}" Margin="8,0,0,0" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <Border Background="{DynamicResource AppSurfaceAlt}" Height="36" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Карта и Окружение" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource AppForeground}" />
                    </Border>
                    <panels:WorldPanelView Grid.Row="1" DataContext="{Binding WorldPanel}" />
                </Grid>
            </Border>

            <!-- RIGHT UTILITY BAR: Icons for Quests, World Map & Help (Column 6) -->
            <Border Grid.Column="6" Width="52" Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1,0,0,0" Padding="0,16" Margin="4,0,0,0">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <ToggleButton Name="QuestsToggle" Content="📜" ToolTip.Tip="Журнал заданий" IsChecked="True" />
                    <ToggleButton Name="WorldToggle" Content="🗺️" ToolTip.Tip="Исследование мира" />
                    <ToggleButton Name="HelpToggle" Content="❓" ToolTip.Tip="Справка (F1)" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- HELP / SHORTCUTS MENU OVERLAY (F1) -->
        <Border Name="HelpOverlay" 
                Background="#D0000000" 
                IsVisible="{Binding #HelpToggle.IsChecked}" 
                Grid.ColumnSpan="7" 
                PointerPressed="OnHelpOverlayClick">
            <Border Background="{DynamicResource AppSurface}" 
                    BorderBrush="{DynamicResource AppBorder}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Width="420" 
                    Height="300" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Padding="24">
                <Grid RowDefinitions="Auto, *, Auto">
                    <TextBlock Text="Горячие клавиши" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppForeground}" Margin="0,0,0,16" />
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="F1 — Показать / скрыть справку" Foreground="{DynamicResource AppForeground}" />
                            <TextBlock Text="Esc — Очистить поле ввода" Foreground="{DynamicResource AppForeground}" />
                            <TextBlock Text="Ctrl + S — Сохранить игру" Foreground="{DynamicResource AppForeground}" />
                            <TextBlock Text="Ctrl + L — Выйти в главное меню" Foreground="{DynamicResource AppForeground}" />
                            <TextBlock Text="Ctrl + Enter — Отправить ход и сфокусировать ввод" Foreground="{DynamicResource AppForeground}" />
                            <TextBlock Text="1, 2, 3, 4 — Переключить вкладки боковой панели" Foreground="{DynamicResource AppForeground}" />
                        </StackPanel>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="Закрыть" Click="OnHelpButtonClick" HorizontalAlignment="Right" Margin="0,16,0,0" />
                </Grid>
            </Border>
        </Border>

        <!-- LEAVE CONFIRMATION WINDOW OVERLAY -->
        <Border Name="LeaveConfirmOverlay" 
                Background="#D0000000" 
                IsVisible="False" 
                Grid.ColumnSpan="7" 
                PointerPressed="OnLeaveConfirmOverlayClick">
            <Border Background="{DynamicResource AppSurface}" 
                    BorderBrush="{DynamicResource AppBorder}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Width="340" 
                    Height="180" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Padding="24">
                <Grid RowDefinitions="*, Auto">
                    <TextBlock Text="Вы действительно хотите выйти из игры? Несохраненный прогресс будет утерян." TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" LineHeight="18" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Да" Click="OnLeaveConfirmAccept" Background="{DynamicResource AppDanger}" />
                        <Button Content="Отмена" Click="OnLeaveConfirmCancel" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
