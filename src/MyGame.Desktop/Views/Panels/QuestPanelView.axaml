<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="600"
             x:Class="MyGame.Desktop.Views.Panels.QuestPanelView"
             x:DataType="vm:QuestPanelViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="12">

            <!-- Search + sort toolbar (issue #69).
                 Sticky at the top of the panel; filters apply to all
                 three sections (active/completed/failed). Sort only
                 affects the active section (completed/failed are short
                 summaries in creation order). -->
            <Border Classes="PanelSection PanelRoot" Padding="6">
                <StackPanel Spacing="6">
                    <TextBox Text="{Binding SearchText}" PlaceholderText="Поиск по названию или описанию…"
                             ToolTip.Tip="Фильтр по всем квестам (без учёта регистра)"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0" ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}"
                                  DisplayMemberBinding="{Binding Label}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Сортировка активных квестов"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Content="Свернуть все" Command="{Binding CollapseAllCommand}"
                                    Classes="TinyButton"
                                    ToolTip.Tip="Свернуть все активные квесты до одной строки"/>
                            <Button Content="Развернуть все" Command="{Binding ExpandAllCommand}"
                                    Classes="TinyButton"
                                    ToolTip.Tip="Развернуть все активные квесты"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <TextBlock Text="Нет квестов" Classes="Muted Small"
                       HorizontalAlignment="Center" Margin="0,24,0,0"
                       IsVisible="{Binding !HasAny}"/>

            <!-- Active quests -->
            <StackPanel Spacing="6" IsVisible="{Binding HasActive}">
                <TextBlock Text="Активные" Classes="SectionTitle"
                           ToolTip.Tip="Текущие активные квесты"/>
                <ItemsControl ItemsSource="{Binding ActiveQuests}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:QuestRow">
                            <Border Classes="QuestRow Active" Padding="8" Margin="0,0,0,6">
                                <StackPanel Spacing="3">
                                    <!-- Row header: clickable to toggle IsExpanded.
                                         The chevron shows ▼ when expanded, ▶ when collapsed. -->
                                    <Button Command="{Binding ToggleExpandedCommand}" Classes="QuestHeaderButton"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            ToolTip.Tip="Свернуть/развернуть квест">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="▼" Classes="Small"
                                                       IsVisible="{Binding IsExpanded}"/>
                                            <TextBlock Grid.Column="0" Text="▶" Classes="Small"
                                                       IsVisible="{Binding !IsExpanded}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Classes="Small"
                                                       Margin="6,0,0,0"/>
                                            <TextBlock Grid.Column="2" Classes="Small Muted">
                                                <Run Text="{Binding CompletedObjectives}"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding TotalObjectives}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Button>
                                    <!-- Collapsible body: description + objectives + rewards.
                                         Hidden when IsExpanded is false. -->
                                    <StackPanel Spacing="3" IsVisible="{Binding IsExpanded}">
                                        <TextBlock Text="{Binding Description}" Classes="Muted Small" TextWrapping="Wrap"/>
                                        <TextBlock Classes="Muted Small" IsVisible="{Binding HasLocation}">
                                            <Run Text="Локация: "/>
                                            <Run Text="{Binding LocationName}"/>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding Objectives}" Margin="0,2,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:QuestObjectiveRow">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1"
                                                                ToolTip.Tip="Цель квеста — отметьте галочкой, когда выполните">
                                                        <TextBlock Text="✓" Classes="Small" Foreground="#10b981"
                                                                   IsVisible="{Binding Done}"/>
                                                        <TextBlock Text="○" Classes="Small Muted"
                                                                   IsVisible="{Binding !Done}"/>
                                                        <TextBlock Text="{Binding Description}" Classes="Small"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border Classes="RewardBox" Padding="6,3" Margin="0,3,0,0"
                                                IsVisible="{Binding HasRewards}">
                                            <TextBlock Classes="Small Muted">
                                                <Run Text="Награда: "/>
                                                <Run Text="{Binding RewardCurrency, StringFormat={}{0} зол.}"/>
                                                <Run Text=", "/>
                                                <Run Text="{Binding RewardExperience, StringFormat={}{0} опыта}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Completed quests -->
            <StackPanel Spacing="6" IsVisible="{Binding HasCompleted}" Margin="0,8,0,0">
                <TextBlock Text="Завершённые" Classes="SectionTitle"
                           ToolTip.Tip="Завершённые квесты"/>
                <ItemsControl ItemsSource="{Binding CompletedQuests}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:QuestRow">
                            <Border Classes="QuestRow Completed" Padding="6,4" Margin="0,0,0,4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="1">
                                        <TextBlock Text="{Binding Name}" Classes="Small" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" Classes="Muted Small" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- Claim-rewards button (issue #70).
                                         Shown only when the quest has
                                         unclaimed rewards (the GM's
                                         update_quest complete staged them
                                         in Quest.UnclaimedRewards). Click
                                         → ClaimRewardsCommand → panel's
                                         ClaimRewardsRequested → GameViewModel
                                         grants currency/XP/items + clears
                                         the field + refreshes. -->
                                    <Button Grid.Column="1" Content="Получить награду"
                                            Command="{Binding ClaimRewardsCommand}"
                                            Classes="TinyButton Primary"
                                            VerticalAlignment="Center"
                                            Margin="6,0,0,0"
                                            IsVisible="{Binding HasUnclaimedRewards}"
                                            ToolTip.Tip="Забрать награду за квест (золото, опыт, предметы)"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Failed quests -->
            <StackPanel Spacing="6" IsVisible="{Binding HasFailed}" Margin="0,8,0,0">
                <TextBlock Text="Проваленные" Classes="SectionTitle"
                           ToolTip.Tip="Проваленные квесты"/>
                <ItemsControl ItemsSource="{Binding FailedQuests}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:QuestRow">
                            <Border Classes="QuestRow Failed" Padding="6,4" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Name}" Classes="Small"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
