<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels.Panels"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="600"
             x:Class="MyGame.Desktop.Views.Panels.CharacterPanelView"
             x:DataType="vm:CharacterPanelViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="12">

            <!-- Identity -->
            <Border Classes="PanelSection">
                <StackPanel Spacing="3">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" FontSize="16"/>
                        <!-- Export this character as a portable .pathstone-char
                             sheet (issue #62). The CharacterPanelVM raises
                             ExportRequested; the GameViewModel handles the
                             actual CharacterSheetStore.Export call. -->
                        <Button Grid.Column="1" Content="Экспорт"
                                Command="{Binding ExportCommand}"
                                Classes="TinyButton"
                                ToolTip.Tip="Экспортировать персонажа в файл (BG3-style перенос между играми)"/>
                    </Grid>
                    <TextBlock Classes="Muted Small">
                        <Run Text="{Binding Race}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Class}"/>
                        <Run Text=" · ур. "/>
                        <Run Text="{Binding Level}"/>
                    </TextBlock>
                    <!-- XP / progression -->
                    <StackPanel Spacing="2" Margin="0,2">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Опыт" Classes="Small Muted"/>
                            <TextBlock Grid.Column="1" Classes="Small Muted" TextAlignment="Right"
                                       FontFamily="Cascadia Mono,Consolas,Menlo,monospace">
                                <Run Text="{Binding Experience}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding NextLevelXp}"/>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Value="{Binding XpProgress}" Maximum="100" Height="4"/>
                    </StackPanel>
                    <TextBlock Classes="Muted Small" Text="{Binding Background}" TextWrapping="Wrap"/>
                    <TextBlock Classes="Muted Small">
                        <Run Text="Скорость: "/>
                        <Run Text="{Binding Speed}"/>
                    </TextBlock>
                    <!-- Inline export status (success / error). Hidden when null. -->
                    <Border Background="#1A2530" BorderBrush="#3B82F6" BorderThickness="1"
                            CornerRadius="3" Padding="6,3" Margin="0,4,0,0"
                            IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ExportStatus}" Classes="Small" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Attributes -->
            <Border Classes="PanelSection" IsVisible="{Binding HasAttributes}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Характеристики" Classes="SectionTitle"
                               ToolTip.Tip="Силовые характеристики персонажа"/>
                    <ItemsControl ItemsSource="{Binding Attributes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:AttributeRow">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="Small"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="Small"
                                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Resources -->
            <Border Classes="PanelSection" IsVisible="{Binding HasResources}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Ресурсы" Classes="SectionTitle"
                               ToolTip.Tip="Здоровье, мана и другие ресурсы"/>
                    <ItemsControl ItemsSource="{Binding Resources}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ResourceRow">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="Small"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="Small"
                                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Equipped -->
            <Border Classes="PanelSection" IsVisible="{Binding HasEquipped}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Экипировка" Classes="SectionTitle"
                               ToolTip.Tip="Надетые предметы по слотам"/>
                    <ItemsControl ItemsSource="{Binding Equipped}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:EquippedRow">
                                <StackPanel Margin="0,1" Spacing="1">
                                    <TextBlock Classes="Small">
                                        <Run Text="{Binding Slot}" Classes="Muted"/>
                                        <Run Text=": "/>
                                        <Run Text="{Binding ItemName}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" Classes="Muted Small" TextWrapping="Wrap"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Active status effects -->
            <Border Classes="PanelSection EffectsSection" IsVisible="{Binding HasEffects}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Эффекты" Classes="SectionTitle"
                               ToolTip.Tip="Активные эффекты и их длительность"/>
                    <ItemsControl ItemsSource="{Binding Effects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:StatusEffectRow">
                                <StackPanel Margin="0,1" Spacing="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Classes="Small"/>
                                        <TextBlock Grid.Column="1" Classes="Small Muted" TextAlignment="Right">
                                            <Run Text="{Binding Duration}"/>
                                            <Run Text=" ход."/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Description}" Classes="Muted Small" TextWrapping="Wrap"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Skills -->
            <Border Classes="PanelSection" IsVisible="{Binding HasSkills}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Владения" Classes="SectionTitle"
                               ToolTip.Tip="Навыки и владения персонажа"/>
                    <WrapPanel>
                        <ItemsControl ItemsSource="{Binding ProficientSkills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="x:String">
                                    <Border Classes="Chip" Padding="6,2" Margin="0,0,4,4">
                                        <TextBlock Text="{Binding}" Classes="Small"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Currency -->
            <Border Classes="PanelSection">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Золото" Classes="Small"/>
                    <TextBlock Grid.Column="1" Text="{Binding Currency}" Classes="Small"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
