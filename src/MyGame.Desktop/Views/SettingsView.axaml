<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MyGame.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <DockPanel LastChildFill="True">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Classes="TopBar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="← Назад" Command="{Binding CancelCommand}" Classes="SmallButton"
                        ToolTip.Tip="Отменить изменения и вернуться в меню"/>
                <TextBlock Grid.Column="1" Text="Настройки" Classes="AppTitle"
                           HorizontalAlignment="Center"/>
                <Button Grid.Column="2" Content="Сохранить" Command="{Binding SaveCommand}"
                        Classes="SmallButton Primary"
                        ToolTip.Tip="Сохранить и вернуться в меню"/>
            </Grid>
        </Border>

        <!-- Error bar -->
        <Border DockPanel.Dock="Top" Classes="ErrorBar"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" />
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24" Spacing="18" MaxWidth="640" HorizontalAlignment="Center">

                <TextBlock Text="Подключение к ИИ (OpenAI-совместимый API)" Classes="SectionTitle"/>
                <StackPanel Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Base URL" Classes="FieldLabel"/>
                        <TextBox Text="{Binding BaseUrl}" PlaceholderText="https://api.openai.com/v1"
                                 ToolTip.Tip="API endpoint, напр. https://api.openai.com/v1"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="API Key" Classes="FieldLabel"/>
                        <TextBox Text="{Binding ApiKey}" PlaceholderText="sk-… (оставьте пустым для локальных серверов)"
                                 PasswordChar="•"
                                 ToolTip.Tip="Ключ API; пусто для локальных серверов"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Модель" Classes="FieldLabel"/>
                        <TextBox Text="{Binding Model}" PlaceholderText="gpt-4o-mini, deepseek-chat, llama3.1:8b…"
                                 ToolTip.Tip="Имя модели по умолчанию, напр. gpt-4o-mini"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Temperature" Classes="FieldLabel"/>
                            <NumericUpDown Value="{Binding Temperature}" Minimum="0" Maximum="2"
                                           Increment="0.1" FormatString="0.0"
                                           ToolTip.Tip="0=детерминированно, 2=креативно"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
                            <TextBlock Text="Max tokens" Classes="FieldLabel"/>
                            <NumericUpDown Value="{Binding MaxTokens}" Minimum="64" Maximum="32000"
                                           Increment="256"
                                           ToolTip.Tip="Лимит токенов на ответ"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Per-role model overrides (issue #26) ───────────────────────── -->
                <TextBlock Text="Модели по ролям (необязательно)" Classes="SectionTitle"
                           ToolTip.Tip="Можно задать разные модели для разных ролей; пусто = использовать основную модель"/>
                <StackPanel Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Планировщик мира (Planner)" Classes="FieldLabel"/>
                        <TextBox Text="{Binding PlannerModel}" PlaceholderText="по умолчанию (= Модель)"
                                 ToolTip.Tip="Модель для планировщика мира (один вызов на генерацию мира). Пусто = основная модель."/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Мастер игры (GM)" Classes="FieldLabel"/>
                        <TextBox Text="{Binding GMModel}" PlaceholderText="по умолчанию (= Модель)"
                                 ToolTip.Tip="Модель для мастера игры (основной цикл, частые вызовы). Пусто = основная модель."/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Нарратор (Narrator)" Classes="FieldLabel"/>
                        <TextBox Text="{Binding NarratorModel}" PlaceholderText="по умолчанию (= Модель)"
                                 ToolTip.Tip="Модель для вступительной наррации мира (один вызов на генерацию). Пусто = основная модель."/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Pet-агент" Classes="FieldLabel"/>
                        <TextBox Text="{Binding PetModel}" PlaceholderText="по умолчанию (= Модель)"
                                 ToolTip.Tip="Модель для делегированных pet-агентов (побочные задачи). Пусто = основная модель."/>
                    </StackPanel>
                    <TextBlock Text="Поля выше необязательны — оставьте пустым, чтобы использовать основную модель."
                               Classes="Muted Small" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Context-window threshold (issue #25) ────────────────────────── -->
                <TextBlock Text="Контекстное окно" Classes="SectionTitle"
                           ToolTip.Tip="Порог суммаризации истории диалога"/>
                <StackPanel Spacing="6">
                    <TextBlock Text="Max context tokens" Classes="FieldLabel"/>
                    <NumericUpDown Value="{Binding MaxContextTokens}" Minimum="1024" Maximum="200000"
                                   Increment="1000" FormatString="0"
                                   ToolTip.Tip="Порог ранней суммаризации истории. 80% от этого значения = старая история сжимается в краткое изложение."/>
                    <TextBlock Text="При превышении 80% от этого порога старая история сжимается в краткое изложение (~300 слов), чтобы не переполнять контекст модели."
                               Classes="Muted Small" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="Никнейм редактируется прямо на главном экране (поле в правом верхнем углу)."
                           Classes="Muted Small" TextWrapping="Wrap"/>

                <Border Classes="Separator"/>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Отмена" Command="{Binding CancelCommand}" Classes="MenuButton"
                            ToolTip.Tip="Отменить изменения"/>
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" Classes="MenuButton Primary"
                            IsEnabled="{Binding !IsBusy}"
                            ToolTip.Tip="Сохранить и вернуться в меню"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
