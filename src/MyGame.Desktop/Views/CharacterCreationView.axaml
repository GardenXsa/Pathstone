<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MyGame.Desktop.Views.CharacterCreationView"
             x:DataType="vm:CharacterCreationViewModel">

    <DockPanel LastChildFill="True">

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Classes="TopBar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="← Назад" Command="{Binding BackCommand}" Classes="SmallButton"
                        ToolTip.Tip="Вернуться в меню"/>
                <TextBlock Grid.Column="1" Text="Создание персонажа" Classes="AppTitle"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="" />
            </Grid>
        </Border>

        <!-- Error bar -->
        <Border DockPanel.Dock="Top" Classes="ErrorBar"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" />
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24" Spacing="18" MaxWidth="720" HorizontalAlignment="Center">

                <TextBlock Text="Создайте своего героя" Classes="ScreenTitle"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Мир готов. Теперь выберите, кем войдёте в него. Стартовые характеристики, снаряжение и владения зависят от класса."
                           Classes="Muted Small" TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Имя" Classes="FieldLabel"/>
                    <TextBox Text="{Binding Name}" PlaceholderText="Например: Странник"
                             ToolTip.Tip="Имя персонажа"/>
                </StackPanel>

                <!-- Race + Class + Background -->
                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                    <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,0">
                        <TextBlock Text="Раса" Classes="FieldLabel"/>
                        <ComboBox ItemsSource="{Binding RaceOptions}"
                                  SelectedItem="{Binding Race}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Выберите расу"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6" Margin="0,0,8,0">
                        <TextBlock Text="Класс" Classes="FieldLabel"/>
                        <ComboBox ItemsSource="{Binding ClassOptions}"
                                  SelectedItem="{Binding Class}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Выберите класс"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock Text="Предыстория" Classes="FieldLabel"/>
                        <ComboBox ItemsSource="{Binding BackgroundOptions}"
                                  SelectedItem="{Binding Background}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Выберите предысторию"/>
                    </StackPanel>
                </Grid>

                <!-- Preview -->
                <Border Classes="InfoBox" Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Предпросмотр класса" Classes="SectionTitle"/>
                        <TextBlock Text="{Binding PreviewText}" Classes="Small"
                                   TextWrapping="Wrap"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="Создать персонажа →" Command="{Binding CreateCommand}"
                            Classes="MenuButton Primary"
                            HorizontalAlignment="Stretch"
                            ToolTip.Tip="Создать персонажа и начать игру"/>
                    <Button Content="В меню" Command="{Binding BackCommand}"
                            Classes="SmallButton"
                            ToolTip.Tip="Вернуться в меню"/>
                </StackPanel>

                <TextBlock Text="После создания персонажа мир загрузится в одиночном режиме. Старый персонаж «Странник» будет заменён."
                           Classes="Muted Small" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
