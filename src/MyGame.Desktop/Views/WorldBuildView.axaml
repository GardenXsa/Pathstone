<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MyGame.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="MyGame.Desktop.Views.WorldBuildView"
             x:DataType="vm:WorldBuildViewModel">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Classes="TopBar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="← Назад" Command="{Binding BackCommand}" Classes="SmallButton"
                        IsVisible="{Binding !IsBusy}"
                        ToolTip.Tip="Вернуться в меню"/>
                <TextBlock Grid.Column="1" Text="Создание мира" Classes="AppTitle"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Classes="ErrorBar"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" />
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,32" Spacing="20" MaxWidth="680" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="Построение мира" Classes="ScreenTitle"
                           HorizontalAlignment="Center"/>

                <!-- Big percent + current stage label -->
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Percent, StringFormat={}{0}%}"
                               FontSize="48" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StageLabel}" Classes="Muted"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding StageDetail}" Classes="Muted Small"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               IsVisible="{Binding StageDetail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <!-- Progress bar -->
                <ProgressBar Value="{Binding Percent}" Maximum="100"
                             Height="8" MinWidth="400"/>

                <!-- Pet-agent progress section (issue #76).
                     Shown only when pet delegations are queued. Each
                     delegation gets a row: status glyph (▶ running / ✓
                     done / ✗ error) + label + summary/error. The
                     section auto-expands when the first delegation
                     starts; the user can also toggle it via the header
                     button. The section stays visible after build
                     completes so the user can review what each pet
                     did. -->
                <Border Classes="InfoBox" Padding="10" MinWidth="500"
                        IsVisible="{Binding HasPetProgress}">
                    <StackPanel Spacing="6">
                        <Button Command="{Binding TogglePetSectionCommand}"
                                Classes="PetSectionHeader"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                ToolTip.Tip="Показать/скрыть детали Pet-агентов">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Text="▼" Classes="Small"
                                           IsVisible="{Binding IsPetSectionExpanded}"/>
                                <TextBlock Grid.Column="0" Text="▶" Classes="Small"
                                           IsVisible="{Binding !IsPetSectionExpanded}"/>
                                <TextBlock Grid.Column="1" Text="Pet-агенты" FontWeight="SemiBold"
                                           Margin="6,0,0,0"/>
                                <TextBlock Grid.Column="2" Classes="Small Muted"
                                           Text="{Binding PetProgress.Count, StringFormat={}{0} делегаций}"/>
                            </Grid>
                        </Button>

                        <ItemsControl ItemsSource="{Binding PetProgress}"
                                      IsVisible="{Binding IsPetSectionExpanded}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PetDelegationProgress">
                                    <Border Margin="0,0,0,4" Padding="6,4"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1" CornerRadius="3">
                                        <StackPanel Spacing="2">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Status glyph: ▶ running / ✓ done / ✗ error / … pending -->
                                                <TextBlock Grid.Column="0" Text="▶" Classes="Small"
                                                           Foreground="#FBBF24"
                                                           IsVisible="{Binding IsRunning}"/>
                                                <TextBlock Grid.Column="0" Text="✓" Classes="Small"
                                                           Foreground="#10B981"
                                                           IsVisible="{Binding IsDone}"/>
                                                <TextBlock Grid.Column="0" Text="✗" Classes="Small"
                                                           Foreground="#F5C2C7"
                                                           IsVisible="{Binding IsError}"/>
                                                <TextBlock Grid.Column="0" Text="…" Classes="Small Muted"
                                                           IsVisible="{Binding IsPending}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                           FontWeight="SemiBold" Classes="Small"
                                                           Margin="6,0,0,0"/>
                                            </Grid>
                                            <!-- Summary shown when done; error shown when failed. -->
                                            <TextBlock Text="{Binding Summary}" Classes="Muted Small"
                                                       TextWrapping="Wrap" Margin="14,0,0,0"
                                                       IsVisible="{Binding Summary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <TextBlock Text="{Binding Error}" Classes="Small"
                                                       Foreground="#F5C2C7" TextWrapping="Wrap" Margin="14,0,0,0"
                                                       IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Final summary (success or failure) -->
                <Border Classes="InfoBox" Padding="14" IsVisible="{Binding FinalSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding FinalSummary}" TextWrapping="Wrap"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"/>
                </Border>

                <!-- Action buttons -->
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <!-- Pause/Resume pair (issue #19). The pause button
                         shows when the build is actively running; the
                         resume button shows when it's paused. Cancel is
                         always available while the build is in flight
                         (whether running or paused) so the user can
                         abort without first resuming. -->
                    <Button Content="Пауза" Command="{Binding PauseCommand}" Classes="MenuButton"
                            IsVisible="{Binding IsRunning}"
                            ToolTip.Tip="Приостановить генерацию (её можно будет продолжить)"/>
                    <Button Content="Продолжить" Command="{Binding ResumeCommand}" Classes="MenuButton Primary"
                            IsVisible="{Binding IsPaused}"
                            ToolTip.Tip="Продолжить приостановленную генерацию"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}" Classes="MenuButton"
                            IsVisible="{Binding IsBusy}"
                            ToolTip.Tip="Остановить генерацию (с сохранением прогресса для возобновления)"/>
                    <Button Content="Продолжить →" Command="{Binding EnterGameCommand}" Classes="MenuButton Primary"
                            IsVisible="{Binding Completed}"
                            ToolTip.Tip="Перейти к созданию персонажа"/>
                    <Button Content="Повторить" Command="{Binding StartCommand}" Classes="MenuButton"
                            IsVisible="{Binding Failed}"
                            ToolTip.Tip="Перезапустить генерацию мира"/>
                    <Button Content="В меню" Command="{Binding BackCommand}" Classes="SmallButton"
                            IsVisible="{Binding Failed}"
                            ToolTip.Tip="Вернуться в меню"/>
                </StackPanel>

                <TextBlock Text="Планировщик AI создаёт структуру мира, затем детерминированный строитель материализует локации, NPC, здания и снаряжение, и наконец нарратор пишет вступление. Это занимает 30-90 секунд."
                           Classes="Muted Small" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
