<Project>
  <!--
    WIN-INSTALLER (issue #4): publish profile for a self-contained
    single-file Windows x64 build. Produces `MyGame.Desktop.exe` +
    native Avalonia libraries extracted alongside (because
    IncludeNativeLibrariesForSelfExtract=true keeps them out of the
    bundle for faster cold-start). The resulting folder is consumed
    by `installer/pathstone.nsi` (NSIS) to build the .exe installer.

    Run via:
        dotnet publish src/MyGame.Desktop/MyGame.Desktop.csproj \
            -p:PublishProfile=win-x64.pubxml
    or via `scripts/build-windows.sh` / `scripts/build-windows.ps1`.
  -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Assembly name + WinExe output type (already set in csproj)
         produce `MyGame.Desktop.exe` as the entry point. PublishDir
         is relative to the project (csproj) directory: two `..\`
         climbs out of `src/MyGame.Desktop/` to the repo root, then
         `publish\win-x64\` is where the build artifacts land. The
         `scripts/build-windows.sh` and `.ps1` scripts override this
         with an explicit -o flag, so the path here is only used
         when invoking `dotnet publish -p:PublishProfile=...`
         directly. -->
    <PublishDir>$(MSBuildProjectDirectory)\..\..\publish\win-x64\</PublishDir>
  </PropertyGroup>
</Project>
